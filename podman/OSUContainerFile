FROM ubuntu:22.04

# Avoid prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    wget \
    libopenmpi-dev \
    openmpi-bin \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Set OpenMPI environment variables
ENV OMPI_ALLOW_RUN_AS_ROOT=1 \
    OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1

# Download and build OSU Micro-Benchmarks
WORKDIR /opt
RUN wget http://mvapich.cse.ohio-state.edu/download/mvapich/osu-micro-benchmarks-7.4.tar.gz && \
    tar -xzf osu-micro-benchmarks-7.4.tar.gz && \
    cd osu-micro-benchmarks-7.4 && \
    ./configure CC=mpicc CXX=mpicxx && \
    make && \
    make install && \
    cd .. && \
    rm osu-micro-benchmarks-7.4.tar.gz

# Add benchmark binaries to PATH
ENV PATH=/usr/local/libexec/osu-micro-benchmarks/mpi/pt2pt:/usr/local/libexec/osu-micro-benchmarks/mpi/collective:/usr/local/libexec/osu-micro-benchmarks/mpi/one-sided:$PATH

WORKDIR /workspace

CMD ["/bin/bash"]