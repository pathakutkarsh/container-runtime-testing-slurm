FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install OpenMPI 4.1.2, build tools, and CA certificates for git
RUN apt-get update && apt-get install -y --no-install-recommends \
        wget \
        make \
        gcc \
        g++ \
        gfortran \
        file \
        autoconf \
        automake \
        libtool \
        pkg-config \
        git \
        ca-certificates \
        openssh-client \
        openmpi-bin \
        libopenmpi-dev \
        && rm -rf /var/lib/apt/lists/*

# Set OpenMPI environment
ENV PATH=/usr/lib/x86_64-linux-gnu/openmpi/bin:$PATH \
    LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/openmpi/lib:$LD_LIBRARY_PATH

# Build IOR from a stable release tag
WORKDIR /tmp
RUN git clone https://github.com/hpc/ior.git && \
    cd ior && \
    git checkout tags/ior-3.3.0 && \
    ./bootstrap && \
    ./configure --prefix=/usr/local/ior CC=mpicc CXX=mpicxx && \
    make -j $(nproc) && \
    make install && \
    cd / && \
    rm -rf /tmp/ior

# Add IOR to PATH
ENV PATH=/usr/local/ior/bin:$PATH

# Verify installation
RUN ior -h

CMD ["/bin/bash"]