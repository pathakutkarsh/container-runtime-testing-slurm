FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install all required packages
RUN apt-get update && apt-get install -y --no-install-recommends \
        wget \
        make \
        gcc \
        g++ \
        gfortran \
        file \
        autoconf \
        automake \
        libtool \
        pkg-config \
        git \
        openssh-client \
        openmpi-bin \
        libopenmpi-dev \
        && rm -rf /var/lib/apt/lists/*

# Set OpenMPI environment
ENV PATH=/usr/lib/x86_64-linux-gnu/openmpi/bin:$PATH \
    LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/openmpi/lib:$LD_LIBRARY_PATH

# Build IOR with verbose output
WORKDIR /tmp
RUN git clone https://github.com/hpc/ior.git && \
    cd ior && \
    git checkout tags/ior-3.3.0 && \          # Use a stable release
    ./bootstrap && \
    ./configure --prefix=/usr/local/ior CC=mpicc CXX=mpicxx && \
    make -j $(nproc) && \
    make install && \
    cd / && \
    rm -rf /tmp/ior

# Verify installation
RUN test -f /usr/local/ior/bin/ior && echo "IOR built successfully" || (echo "IOR build failed" && exit 1)

ENV PATH=/usr/local/ior/bin:$PATH
CMD ["/bin/bash"]